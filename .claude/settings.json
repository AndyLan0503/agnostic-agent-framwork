{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(terraform fmt*)",
      "Bash(terraform validate*)",
      "Bash(python3 scripts/gnhf.py *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*serviceaccount*.json)"
    ]
  }
}
